# Example /etc/backup/env file
# Copy this to /etc/backup/env and fill in your values

# Restic repository URL (REST server)
RESTIC_REPOSITORY="rest:https://backup-client:PASSWORD@backups.example.com/"

# Path to the file containing the repository encryption password
RESTIC_PASSWORD_FILE="/etc/backup/restic-password"

# Directory for restic cache
RESTIC_CACHE_DIR="/var/cache/restic"
