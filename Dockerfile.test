# Multi-stage Dockerfile for integration testing with systemd and restic
# Stage 1: Build the bak binary
FROM golang:1.21-bookworm AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /bak ./cmd/bak

# Stage 2: Test environment with systemd and restic
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV container=docker

# Install systemd and required packages
RUN apt-get update && apt-get install -y \
    systemd \
    systemd-sysv \
    dbus \
    curl \
    ca-certificates \
    bzip2 \
    && rm -rf /var/lib/apt/lists/*

# Install Go for running tests
RUN curl -LO https://go.dev/dl/go1.21.13.linux-amd64.tar.gz \
    && tar -C /usr/local -xzf go1.21.13.linux-amd64.tar.gz \
    && rm go1.21.13.linux-amd64.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOPATH="/go"
ENV PATH="${GOPATH}/bin:${PATH}"

# Install restic v0.16.4
RUN curl -LO https://github.com/restic/restic/releases/download/v0.16.4/restic_0.16.4_linux_amd64.bz2 \
    && bunzip2 restic_0.16.4_linux_amd64.bz2 \
    && mv restic_0.16.4_linux_amd64 /usr/local/bin/restic \
    && chmod +x /usr/local/bin/restic

# Clean up systemd units that cause issues in containers
RUN rm -f /lib/systemd/system/multi-user.target.wants/* \
    && rm -f /etc/systemd/system/*.wants/* \
    && rm -f /lib/systemd/system/local-fs.target.wants/* \
    && rm -f /lib/systemd/system/sockets.target.wants/*udev* \
    && rm -f /lib/systemd/system/sockets.target.wants/*initctl* \
    && rm -f /lib/systemd/system/sysinit.target.wants/systemd-tmpfiles-setup* \
    && rm -f /lib/systemd/system/systemd-update-utmp*

# Create config directory
RUN mkdir -p /etc/backup

# Copy bak binary from builder
COPY --from=builder /bak /usr/local/bin/bak

# Copy source code for running tests
WORKDIR /app
COPY . .

# Download test dependencies
RUN go mod download

# Set environment variables for restic
ENV RESTIC_REPOSITORY=/tmp/restic-repo
ENV RESTIC_PASSWORD=test-password

# Also set them in profile so they're available in interactive shells
RUN echo 'export RESTIC_REPOSITORY=/tmp/restic-repo' >> /etc/profile.d/restic.sh \
    && echo 'export RESTIC_PASSWORD=test-password' >> /etc/profile.d/restic.sh \
    && chmod +x /etc/profile.d/restic.sh

# Create initialization script (runs before tests)
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
# Initialize restic repository if it does not exist\n\
if [ ! -d "$RESTIC_REPOSITORY" ]; then\n\
    restic init\n\
fi\n\
\n\
# Create test data directory\n\
mkdir -p /tmp/backup-source\n\
echo "test file 1" > /tmp/backup-source/file1.txt\n\
echo "test file 2" > /tmp/backup-source/file2.txt\n\
mkdir -p /tmp/backup-source/subdir\n\
echo "nested file" > /tmp/backup-source/subdir/nested.txt\n\
' > /usr/local/bin/init-test-env.sh && chmod +x /usr/local/bin/init-test-env.sh

# Create test runner script
RUN echo '#!/bin/bash\n\
cd /app\n\
go test -v -tags=integration ./test/integration/...\n\
EXIT_CODE=$?\n\
echo "Tests completed with exit code: $EXIT_CODE"\n\
# Save exit code and shutdown\n\
echo $EXIT_CODE > /tmp/test-exit-code\n\
if [ $EXIT_CODE -eq 0 ]; then\n\
    systemctl poweroff\n\
else\n\
    # Give time to see output before shutdown\n\
    sleep 2\n\
    systemctl poweroff --force\n\
fi\n\
' > /usr/local/bin/run-tests.sh && chmod +x /usr/local/bin/run-tests.sh

# Create systemd service for initializing test environment (always runs)
RUN echo '[Unit]\n\
Description=Initialize Test Environment\n\
After=local-fs.target\n\
\n\
[Service]\n\
Type=oneshot\n\
Environment="RESTIC_REPOSITORY=/tmp/restic-repo"\n\
Environment="RESTIC_PASSWORD=test-password"\n\
ExecStart=/usr/local/bin/init-test-env.sh\n\
RemainAfterExit=yes\n\
\n\
[Install]\n\
WantedBy=multi-user.target\n\
' > /etc/systemd/system/init-test-env.service

# Create systemd service for running tests (only when AUTO_RUN_TESTS=1)
RUN echo '[Unit]\n\
Description=Integration Tests\n\
After=init-test-env.service\n\
Requires=init-test-env.service\n\
ConditionEnvironment=AUTO_RUN_TESTS=1\n\
\n\
[Service]\n\
Type=oneshot\n\
Environment="RESTIC_REPOSITORY=/tmp/restic-repo"\n\
Environment="RESTIC_PASSWORD=test-password"\n\
ExecStart=/usr/local/bin/run-tests.sh\n\
StandardOutput=journal+console\n\
StandardError=journal+console\n\
RemainAfterExit=yes\n\
\n\
[Install]\n\
WantedBy=multi-user.target\n\
' > /etc/systemd/system/integration-tests.service

# Enable both services
RUN systemctl enable init-test-env.service integration-tests.service

# Use systemd as init
STOPSIGNAL SIGRTMIN+3
CMD ["/lib/systemd/systemd"]
